# Copy this file to .env and fill in real values. .env is gitignored;
# never commit real secrets.

# ── Shared PostgreSQL database ─────────────────────────────────────
# Used by the app (core/db.py) to connect to the Verification Registry
# and Audit Log. Also used by docker-compose.yml to configure the local
# Postgres container's own credentials - for local development, point
# DATABASE_URL at localhost using the same values as POSTGRES_USER/
# POSTGRES_PASSWORD/POSTGRES_DB below. For a shared/production setup,
# point it at the cloud VM's address instead, once the database stack
# is deployed there (see README "Deployment: shared database").
POSTGRES_USER=npl_docseal
POSTGRES_PASSWORD=change-me-to-a-real-password
POSTGRES_DB=npl_docseal
DATABASE_URL=postgresql://npl_docseal:change-me-to-a-real-password@localhost:5432/npl_docseal

# ── Ethereum Sepolia (testnet) blockchain anchoring ────────────────
SEPOLIA_RPC_URL=
SEPOLIA_WALLET=
SEPOLIA_PRIVATE_KEY=

# ── Internal dashboard access gate (optional) ──────────────────────
# Leave unset to leave the dashboard open (local dev). Set it to
# require this value as the X-Dashboard-Key header before sealing or
# clearing the audit log.
DASHBOARD_PASSWORD=

# ── Demo RSA keypair passphrase (optional) ─────────────────────────
# Only used if keys/private_key.pem and keys/public_key.pem don't
# already exist - core/startup.py generates a fresh demo keypair with
# this passphrase on a container/environment that has no real keys yet.
DEMO_KEY_PASSPHRASE=demo-passphrase-change-me
